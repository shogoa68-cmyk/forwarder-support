# ========== macOS ==========
.DS_Store
._*

# ========== Claude 関連（worktree や一時データ） ==========
.claude/
# ただしプロジェクト共有用のサブエージェント定義は追跡する
!.claude/agents/
!.claude/agents/*

# ========== バックアップファイル群 ==========
# Phase 2b / 2c で量産したもの + ユーザー手動バックアップ
*.bak
*.bak[0-9]*
*.bak_*
*_bak_*
index_bak_*
*.original
*.orig

# ========== macOS Finder エイリアス（バイナリ、git で扱えない） ==========
*エイリアス

# ========== iCloud 同期プレースホルダ ==========
*.icloud

# ========== ログ・一時ファイル ==========
*.log
*.tmp
*.swp
*~

# ========== 一般的な開発生成物（このプロジェクトは Vanilla JS なので通常は発生しないが念のため） ==========
node_modules/
__pycache__/
*.pyc
dist/
build/
